Proceso Ejercicio_2_1
	Definir num Como Real;
	Escribir 'Ingresa un nºmero para saber si es positivo, negativo o igual a 0';
	Leer num;
	Si num==0 Entonces
		Escribir 'El nºmero es igual a 0';
	SiNo
		Si num<0 Entonces
			Escribir 'El nºmero es negativo';
		SiNo
			Escribir 'El nºmero es positivo';
		FinSi
	FinSi
FinProceso
